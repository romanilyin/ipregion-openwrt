    "SPOTIFY_SIGNUP": { "group": "custom", "name": "Spotify Signup", "default_enabled": true, "method": "GET", "url": "https://spclient.wg.spotify.com/signup/public/v1/account/?validate=1&key={spotify_api_key}", "headers": {}, "handler": "spotify_signup", "extract": { "type": "handler" } },
    "DISNEY_PLUS_ACCESS": { "group": "custom", "name": "Disney+ Access", "default_enabled": true, "method": "POST", "url": "https://disney.api.edge.bamgrid.com/graph/v1/device/graphql", "headers": {}, "handler": "disney_plus_access", "extract": { "type": "handler" } },
    "APPLE": { "group": "custom", "name": "Apple", "default_enabled": true, "method": "GET", "url": "https://gspe1-ssl.ls.apple.com/pep/gcc", "headers": {}, "handler": "apple_country", "extract": { "type": "plain_trim" } },
    "STEAM": { "group": "custom", "name": "Steam", "default_enabled": true, "method": "HEAD", "url": "https://store.steampowered.com", "headers": {}, "handler": "steam_country", "extract": { "type": "regex", "pattern": "steamCountry=([^%;]+)" } },
    "TIKTOK": { "group": "custom", "name": "Tiktok", "default_enabled": true, "method": "GET", "url": "https://www.tiktok.com/api/v1/web-cookie-privacy/config?appId=1988", "headers": {}, "handler": "tiktok_country", "extract": { "type": "json", "path": ["body", "appProps", "region"] } },
