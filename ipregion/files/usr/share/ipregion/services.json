    },
    "IPREGISTRY": {
      "group": "primary",
      "name": "ipregistry.co",
      "default_enabled": true,
      "method": "GET",
      "url": "https://api.ipregistry.co/{ip}?hostname=true&key=sb69ksjcajfs4c",
      "self_url": "https://api.ipregistry.co/?hostname=true&key=sb69ksjcajfs4c",
      "headers": { "Origin": "https://ipregistry.co" },
      "extract": { "type": "json", "path": ["location", "country", "code"] }
    },
    "IPAPI_CO": {
      "group": "primary",
      "name": "ipapi.co",
      "default_enabled": true,
      "method": "GET",
      "url": "https://ipapi.co/{ip}/json",
      "self_url": "https://ipapi.co/json",
      "headers": {},
      "extract": { "type": "json", "path": ["country"] }
    },
