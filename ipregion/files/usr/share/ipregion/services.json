    "PLAYSTATION": { "group": "custom", "name": "PlayStation", "default_enabled": true, "method": "HEAD", "url": "https://www.playstation.com", "headers": {}, "handler": "playstation_country", "extract": { "type": "regex", "pattern": "country=([^;]+)" } },
    "MICROSOFT": { "group": "custom", "name": "Microsoft", "default_enabled": true, "method": "GET", "url": "https://login.live.com", "headers": {}, "handler": "microsoft_country", "extract": { "type": "regex", "pattern": "\\\"sRequestCountry\\\":\\\"([^\\\"]+)" } },
    "CLOUDFLARE_CDN": { "group": "cdn", "name": "Cloudflare CDN", "default_enabled": true, "method": "GET", "url": "https://speed.cloudflare.com/meta", "headers": { "Referer": "https://speed.cloudflare.com" }, "handler": "cloudflare_cdn", "extract": { "type": "handler" } },
    "YOUTUBE_CDN": { "group": "cdn", "name": "YouTube CDN", "default_enabled": true, "method": "GET", "url": "https://redirector.googlevideo.com/report_mapping?di=no", "headers": {}, "handler": "youtube_cdn", "extract": { "type": "handler" } },
    "NETFLIX_CDN": { "group": "cdn", "name": "Netflix CDN", "default_enabled": true, "method": "GET", "url": "https://api.fast.com/netflix/speedtest/v2?https=true&token={netflix_api_key}&urlCount=1", "headers": {}, "handler": "netflix_cdn", "extract": { "type": "json", "path": ["targets", 0, "location", "country"] } }
