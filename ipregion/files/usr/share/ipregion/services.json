  "services": {
    "MAXMIND": {
      "group": "primary",
      "name": "maxmind.com",
      "default_enabled": true,
      "method": "GET",
      "url": "https://geoip.maxmind.com/geoip/v2.1/city/me",
      "headers": { "Referer": "https://www.maxmind.com" },
      "extract": { "type": "json", "path": ["country", "iso_code"] }
    },
    "RIPE": {
      "group": "primary",
      "name": "rdap.db.ripe.net",
      "default_enabled": true,
      "method": "GET",
      "url": "https://rdap.db.ripe.net/ip/{ip}",
      "headers": {},
      "extract": { "type": "json", "path": ["country"] }
    },
    "IPINFO_IO": {
      "group": "primary",
      "name": "ipinfo.io",
      "default_enabled": true,
      "method": "GET",
      "url": "https://ipinfo.io/widget/demo/{ip}",
      "self_url": "https://ipinfo.io/json",
      "headers": {},
      "extract": { "type": "json", "path": ["data", "country"] },
      "self_extract": { "type": "json", "path": ["country"] },
      "ipv6_transport": "ipv4_with_ipv6_param"
    },
    "CLOUDFLARE": {
      "group": "primary",
      "name": "cloudflare.com",
      "default_enabled": true,
      "method": "GET",
      "url": "https://speed.cloudflare.com/meta",
