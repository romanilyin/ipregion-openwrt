config ipregion 'main'
	option enabled '1'
	option group 'all'
	option ip_mode 'auto'
	option geoip_mode 'lookup'
	option timeout '5'
	option retries '1'
	option proxy ''
	option proxy_dns 'remote'
	option interface ''
	option mask_ip '1'
	option cache_ttl '300'
	option max_parallel '3'
	option debug '0'
	option keep_logs '0'
	list disabled_service 'GOOGLE_SEARCH_CAPTCHA'
