msgstr "TTL кэша"

msgid "CDN services"
msgstr "CDN-сервисы"

msgid "CDN services check which CDN edge or region the router reaches, for example Cloudflare, YouTube or Netflix."
msgstr "CDN-сервисы проверяют, до какого CDN edge или региона доходит роутер, например Cloudflare, YouTube или Netflix."

msgid "Category"
msgstr "Категория"

msgid "Check how GeoIP, streaming and CDN services detect this router."
msgstr "Проверяет, как GeoIP, стриминговые и CDN-сервисы видят этот роутер."

msgid "Check how GeoIP, streaming, CDN and AI services detect this router."
msgstr "Проверяет, как GeoIP, стриминговые, CDN и AI-сервисы видят этот роутер."

msgid "Check discovered IP"
msgstr "Проверять обнаруженный IP"

msgid "Check service-visible route"
msgstr "Проверять маршрут глазами сервиса"

msgid "Check whether popular AI API endpoints are reachable through this router, interface or SOCKS5 proxy."
msgstr "Проверяет, доступны ли популярные AI API endpoint-ы через этот роутер, интерфейс или SOCKS5-прокси."

msgid "Check whether popular AI API endpoints are reachable through the selected route."
msgstr "Проверяет, доступны ли популярные AI API endpoint-ы через выбранный маршрут."

msgid "China and Asia AI providers"
msgstr "AI-провайдеры Китая и Азии"

msgid "Clear cache"
msgstr "Очистить кэш"

msgid "Close"
msgstr "Закрыть"

msgid "Configure default diagnostics options."
msgstr "Настройка параметров диагностики по умолчанию."

msgid "Country"
msgstr "Страна"

msgid "Current check"
msgstr "Текущая проверка"

msgid "Debug logging"
msgstr "Отладочный лог"

