msgid "All"
msgstr "Все"

msgid "All groups run every enabled GeoIP, popular service and CDN check."
msgstr "Все группы запускают все включенные проверки GeoIP, популярных сервисов и CDN."

msgid "All AI providers"
msgstr "Все AI-провайдеры"

msgid "All providers"
msgstr "Все провайдеры"

msgid "AI category"
msgstr "Категория AI"

msgid "AI provider check started"
msgstr "Проверка AI-провайдеров запущена"

msgid "AI provider checks use the same IP mode, interface, proxy and timeout controls above."
msgstr "AI-проверки используют выбранные выше режим IP, интерфейс, прокси и таймаут."

msgid "AI provider endpoint results"
msgstr "Результаты endpoint-ов AI-провайдеров"

msgid "AI Providers"
msgstr "AI-провайдеры"

msgid "ASN"
msgstr "ASN"

msgid "Auto"
msgstr "Авто"

